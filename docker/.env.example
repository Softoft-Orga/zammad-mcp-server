# Zammad API Configuration
ZAMMAD_URL=http://localhost:8080
ZAMMAD_HTTP_TOKEN=your_api_token_here

# Alternative authentication methods
# ZAMMAD_OAUTH2_TOKEN=your_oauth_token
# ZAMMAD_USERNAME=admin@example.com
# ZAMMAD_PASSWORD=your_password

# MCP Server Configuration
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# Access Control Configuration
# Comma-separated list of allowed tool categories
# Categories: tickets, users, organizations, groups, admin, search, all
MCP_ALLOWED_CATEGORIES=all

# Comma-separated list of denied tools (overrides allowed categories)
MCP_DENIED_TOOLS=delete_ticket

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Caching
CACHE_TTL_SECONDS=300
MAX_CACHE_SIZE=1000
